{
  "name": "ace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:seed": "dotenv -e .env.local -- tsx scripts/seed.ts"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@prisma/client": "^6.19.3",
    "next": "15.5.9",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.18",
    "@types/node": "20.14.9",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "9.10.0",
    "eslint-config-next": "15.5.9",
    "postcss": "8.4.45",
    "prisma": "^6.19.3",
    "tailwindcss": "4.1.18",
    "tsx": "^4.22.4",
    "typescript": "5.6.3",
    "vitest": "^2.1.9"
  }
}
