      "id": "seg-300-97",
      "start": 510.1000061035156,
      "end": 511.1000061035156,
      "text": "뒤집 주시고",
      "timestamp": "08:30"
    },
    {
      "id": "seg-300-98",
      "start": 511.1000061035156,
      "end": 512.1000061035156,
      "text": "반복해주시겠 요?",
      "timestamp": "08:31"
    },
    {
      "id": "seg-300-99",
      "start": 512.1000061035156,
      "end": 514.1000061035156,
      "text": "네, 좋습니다",
      "timestamp": "08:32"
    },
