      "id": "seg-300-100",
      "start": 514.1000061035156,
      "end": 515.1000061035156,
      "text": "한 가지 더 해볼게요",
      "timestamp": "08:34"
    },
    {
      "id": "seg-300-101",
      "start": 515.1000061035156,
      "end": 517.1000061035156,
      "text": "손가락을 맞춰보시는데",
