    },
    {
      "id": "seg-300-86",
      "start": 494.1000061035156,
      "end": 495.1000061035156,
      "text": "네, 좋습니다",
      "timestamp": "08:14"
    },
    {
      "id": "seg-300-87",
      "start": 495.1000061035156,
      "end": 496.1000061035156,
      "text": "이렇게 해보시고",
      "timestamp": "08:15"
    },
    {
      "id": "seg-300-88",
      "start": 496.1000061035156,
      "end": 497.1000061035156,
      "text": "버텨보세요",
