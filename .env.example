# ============================================================
# ACE CPX 채점 연구 플랫폼 — 환경변수 템플릿
# 이 파일은 커밋됨(시크릿 금지, 플레이스홀더만).
# 실제 값은 .env.local 에 넣으세요 (.env.local 은 .gitignore 처리됨).
# ============================================================

# --- DB: Prisma → Supabase Postgres (서울 ap-northeast-2, IRB 데이터 상주) ---
# Supabase 대시보드 → Connect → ORMs → Prisma 에서 아래 두 값 복사.
# 앱 런타임: 풀러(pgbouncer, 6543)
DATABASE_URL="postgresql://postgres.<ref>:<db-password>@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# 마이그레이션(prisma migrate): 다이렉트(5432)
DIRECT_URL="postgresql://postgres.<ref>:<db-password>@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"

# --- 인증: rater×session 토큰 서명 시크릿 (HMAC) ---
# 관리자(/admin) 세션 쿠키도 이 시크릿으로 서명됨 (lib/auth/admin.ts).
# 생성: openssl rand -base64 48
SESSION_TOKEN_SECRET=

# --- 관리자 시드 비밀번호 (scripts/seed.ts, 신규 admin 생성 시에만 사용) ---
# 시드 후 실제 운영에선 관리자별로 개별 변경 권장. 기존 admin은 재시드해도 유지됨.
ADMIN_SEED_PASSWORD=

# --- OpenAI: 전사 + Mode B 근거발화 추출 (lib/openai.ts) ---
OPENAI_KEY=

# --- 미디어 도구 (옵션; 미설정 시 PATH 에서 탐색) ---
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# --- 영상 소스: S3 (클라이언트 노출 NEXT_PUBLIC_*) ---
NEXT_PUBLIC_S3_BUCKET_NAME=
NEXT_PUBLIC_S3_REGION=ap-northeast-2
