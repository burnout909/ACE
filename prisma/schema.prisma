generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Mode {
  A
  B
}

enum Section {
  Hx
  PEx
  Edu
}

enum Scale {
  binary
  triple
}

enum SessionStatus {
  locked
  active
  done
}

enum ProgressState {
  not_started
  in_progress
  submitted
  locked
}

model Rater {
  id           String       @id
  name         String
  pinHash      String       @map("pin_hash")
  pinSalt      String       @map("pin_salt")
  contact      String?
  scheduleSeed Int          @map("schedule_seed")
  sessions     Session[]
  assignments  Assignment[]
  events       Event[]
  pinAttempts  PinAttempt[]

  @@map("raters")
}

model Case {
  id          Int          @id
  videoUrls   Json         @map("video_urls")
  phenotype   String       @default("두통")
  assignments Assignment[]
  content     CaseContent?

  @@map("cases")
}

model ChecklistItem {
  id       String   @id
  section  Section
  scale    Scale
  text     String
  criteria String   @db.Text
  ord      Int
  answers  Answer[]

  @@map("checklist_items")
}

model Session {
  raterId       String        @map("rater_id")
  period        Int
  status        SessionStatus @default(locked)
  windowOpenAt  DateTime?     @map("window_open_at") @db.Timestamptz(6)
  windowCloseAt DateTime?     @map("window_close_at") @db.Timestamptz(6)
  rater         Rater         @relation(fields: [raterId], references: [id])

  @@id([raterId, period])
  @@map("sessions")
}

model Assignment {
  id         Int           @id @default(autoincrement())
  raterId    String        @map("rater_id")
  caseId     Int           @map("case_id")
  period     Int
  mode       Mode
  orderIndex Int           @map("order_index")
  rater      Rater         @relation(fields: [raterId], references: [id])
  case       Case          @relation(fields: [caseId], references: [id])
  progress   CaseProgress?
  answers    Answer[]
  events     Event[]

  @@unique([raterId, caseId, period])
  @@map("assignments")
}

model CaseProgress {
  assignmentId Int           @id @map("assignment_id")
  state        ProgressState @default(not_started)
  activeMs     Int           @default(0) @map("active_ms")
  enterAt      DateTime?     @map("enter_at") @db.Timestamptz(6)
  submitAt     DateTime?     @map("submit_at") @db.Timestamptz(6)
  assignment   Assignment    @relation(fields: [assignmentId], references: [id])

  @@map("case_progress")
}

model Answer {
  assignmentId Int           @map("assignment_id")
  itemId       String        @map("item_id")
  value        Int
  decidedAt    DateTime      @default(now()) @map("decided_at") @db.Timestamptz(6)
  revisedCount Int           @default(0) @map("revised_count")
  assignment   Assignment    @relation(fields: [assignmentId], references: [id])
  item         ChecklistItem @relation(fields: [itemId], references: [id])

  @@id([assignmentId, itemId])
  @@map("answers")
}

model Event {
  id           String      @id                    // client-generated uuid (crypto.randomUUID), dedup key
  raterId      String      @map("rater_id")
  assignmentId Int?        @map("assignment_id")
  type         String
  payload      Json        @default("{}")
  section      String?
  mode         Mode?
  clientTs     DateTime?   @map("client_ts") @db.Timestamptz(6)
  serverTs     DateTime    @default(now()) @map("server_ts") @db.Timestamptz(6)
  rater        Rater       @relation(fields: [raterId], references: [id])
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])

  @@index([raterId, assignmentId, serverTs])
  @@map("events")
}

model PinAttempt {
  id      Int      @id @default(autoincrement())
  raterId String   @map("rater_id")
  at      DateTime @default(now()) @db.Timestamptz(6)
  rater   Rater    @relation(fields: [raterId], references: [id])

  @@index([raterId, at])
  @@map("pin_attempts")
}

model Admin {
  id           String         @id
  email        String         @unique
  name         String
  passwordHash String         @map("password_hash")
  passwordSalt String         @map("password_salt")
  auditLogs    AuditLog[]
  attempts     AdminAttempt[]

  @@map("admins")
}

model AdminAttempt {
  id      Int      @id @default(autoincrement())
  adminId String   @map("admin_id")
  at      DateTime @default(now()) @db.Timestamptz(6)
  admin   Admin    @relation(fields: [adminId], references: [id])

  @@index([adminId, at])
  @@map("admin_attempts")
}

model AuditLog {
  id      BigInt   @id @default(autoincrement())
  adminId String   @map("admin_id")
  action  String
  target  String?
  reason  String?
  ts      DateTime @default(now()) @db.Timestamptz(6)
  admin   Admin    @relation(fields: [adminId], references: [id])

  @@index([ts])
  @@map("audit_log")
}

// Per-case transcript + Mode-B evidence. Populated by Plan 4 (transcript
// pipeline); reviewed/corrected in /admin, then frozen. Only frozen=true
// content is served as Mode-B evidence (see app/api/case GET).
model CaseContent {
  caseId    Int      @id @map("case_id")
  transcript Json    @default("[]") // TranscriptSegment[]
  evidence  Json     @default("[]") // { itemId, quote, ts }[]
  modelId   String?  @map("model_id") // frozen LLM version for reproducibility
  frozen    Boolean  @default(false)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  case      Case     @relation(fields: [caseId], references: [id])

  @@map("case_content")
}

// AI Yes/No verdicts, isolated from rater-facing content (study design forbids
// exposing the AI verdict to evaluators). Used only for the GS-vs-AI-alone
// accuracy analysis. Written by the Plan 4 pipeline, never served to raters.
model AiAlone {
  caseId    Int      @map("case_id")
  itemId    String   @map("item_id")
  verdict   String?
  modelId   String   @map("model_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([caseId, itemId])
  @@map("ai_alone")
}
